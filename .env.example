GOOGLE_API_KEY=your-google-api-key
GOOGLE_GENAI_API_KEY=your-google-genai-api-key
BIGQUERY_DATASET=analytics
# For local dev with emulator:
# BIGQUERY_EMULATOR_HOST=localhost:9050
# GOOGLE_CLOUD_PROJECT=local-project
# For production:
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
DATABASE_URL=postgresql+asyncpg://adk:adk@localhost:5432/adk_sessions
# Redis query result cache — leave empty to use in-memory fallback (single instance only)
REDIS_URL=redis://localhost:6379/0
MODEL_PLANNER=gemini-2.5-pro
MODEL_EXECUTOR=gemini-2.5-flash
MODEL_CRITIC=gemini-2.5-pro
API_HOST=0.0.0.0
API_PORT=8080
